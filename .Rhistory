read_banphaeo_kmz <- function(kmz_path) {
tmpdir <- tempfile("kmz_")
dir.create(tmpdir)
unzip(kmz_path, exdir = tmpdir)
kml_file <- list.files(tmpdir, pattern = "\\.kml$", full.names = TRUE)[1]
shp <- sf::st_read(kml_file, quiet = TRUE)
shp <- shp %>%
sf::st_zm(drop = TRUE) %>%          # remove Z dimension
sf::st_make_valid() %>%             # repair invalid geometry
sf::st_cast("MULTIPOLYGON") %>%     # ensure polygon structure
sf::st_transform(4326)              # leaflet CRS
nm <- names(shp)
name_col <- nm[grepl("name", nm, ignore.case = TRUE)][1]
desc_col <- nm[grepl("description", nm, ignore.case = TRUE)][1]
shp <- shp %>%
mutate(
name_raw = as.character(.data[[name_col]]),
description_text = as.character(.data[[desc_col]]),
province_th = extract_desc_field(description_text, "P_NAME_T"),
district_th = extract_desc_field(description_text, "A_NAME_T"),
subdistrict_th = extract_desc_field(description_text, "T_NAME_T"),
subdistrict_th = ifelse(is.na(subdistrict_th), name_raw, subdistrict_th),
subdistrict_clean = clean_subdistrict(subdistrict_th)
)
shp %>%
filter(
!is.na(district_th),
district_th == "บ้านแพ้ว"
) %>%
select(subdistrict_th, subdistrict_clean, geometry)
}
