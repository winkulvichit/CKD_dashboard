ggplot(df_monitor_filtered, aes(x = as.factor(day), y = crcl, fill = arm)) +
geom_boxplot(alpha = 0.6, position = position_dodge(width = 0.8), outlier.shape = NA) +  # Dodge for separation
coord_cartesian(ylim = c(0, 250)) +  # Focus on y-values below 0.6
labs(
