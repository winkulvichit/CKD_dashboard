mutate(
creatinine = suppressWarnings(as.numeric(creatinine))  # ensure numeric
) %>%
filter(day %in% 1:14) %>%
group_by(id, an, day) %>%
summarise(cr = suppressWarnings(max(creatinine, na.rm = TRUE)), .groups = "drop") %>%
mutate(
cr  = ifelse(is.infinite(cr), NA_real_, cr),   # all-NA safety after max()
day = factor(day, levels = 1:14)               # ensure all 1..14 appear
) %>%
tidyr::pivot_wider(
names_from   = day,
values_from  = cr,
names_prefix = "cr_day",
names_expand = TRUE,
values_fill  = list(cr = NA_real_)            # <-- must be a named list
)
# Result columns: cr_day1 : cr_day14
# 2) Merge into df_first (wide)
df_merged <- df_merged %>% left_join(cr_d1to14, by = c("id", "an"))
# ensure types and baseline
day_cols <- paste0("cr_day", 1:14)
# 0) Ensure numeric and baseline
df_merged <- df_merged %>%
mutate(
across(c(cr_base, cr_start, all_of(day_cols)), ~ suppressWarnings(as.numeric(.))),
base_for_calc = dplyr::coalesce(cr_base, cr_start)
)
# 1) Build creatinine matrix (n x 14)
CR <- as.matrix(df_merged[, day_cols, drop = FALSE])  # numeric with NA
B  <- df_merged$base_for_calc                         # length n
# 2) Compute ratio and absolute increase (row-wise via sweep)
RATIO   <- sweep(CR, 1, B, "/")                       # CR / baseline
ABS_INC <- sweep(CR, 1, B, "-")                       # CR - baseline
# NA-safe helpers (return logical, treating NA as FALSE)
ge <- function(X, v) !is.na(X) & (X >= v)
lt <- function(X, v) !is.na(X) & (X <  v)
# 3) KDIGO rule masks (logical matrices n x 14)
stg3 <- ge(RATIO, 3) | ge(CR, 4)                      # (RRT not included here)
stg2 <- ge(RATIO, 2) & lt(RATIO, 3)
stg1 <- (ge(RATIO, 1.5) & lt(RATIO, 2)) | (ge(ABS_INC, 0.3) & lt(RATIO, 2))
# 4) Stage matrix (integer; NA stays NA where CR is NA)
STG <- matrix(0L, nrow = nrow(CR), ncol = ncol(CR))
STG[stg1] <- 1L
STG[stg2] <- 2L
STG[stg3] <- 3L
STG[is.na(CR)] <- NA_integer_
# 5) Onset day (first column where stage >= 1), type-stable
onset_any <- apply(STG >= 1, 1, function(row) {
row[is.na(row)] <- FALSE
idx <- which(row)
if (length(idx)) idx[1] else NA_integer_
})
# Severe onset (stage >= 2)
onset_sev <- apply(STG >= 2, 1, function(row) {
row[is.na(row)] <- FALSE
idx <- which(row)
if (length(idx)) idx[1] else NA_integer_
})
# 6) Peaks by horizon
peak7  <- apply(STG[, 1:7,  drop = FALSE], 1, function(row) if (all(is.na(row))) NA_integer_ else as.integer(max(row, na.rm = TRUE)))
peak14 <- apply(STG[, 1:14, drop = FALSE], 1, function(row) if (all(is.na(row))) NA_integer_ else as.integer(max(row, na.rm = TRUE)))
# 7) Flags from onsets (then convert to factors)
aki7        <- as.integer(!is.na(onset_any) & onset_any <= 7L)
aki14       <- as.integer(!is.na(onset_any) & onset_any <= 14L)
sev_aki7    <- as.integer(!is.na(onset_sev) & onset_sev <= 7L)
sev_aki14   <- as.integer(!is.na(onset_sev) & onset_sev <= 14L)
df_merged <- df_merged %>%
mutate(
aki_onset_day      = onset_any,
aki_onset_stage    = vapply(seq_len(nrow(STG)), function(i) { d <- onset_any[i]; if (is.na(d)) NA_integer_ else STG[i, d] }, integer(1)),
severe_onset_day   = onset_sev,
severe_onset_stage = vapply(seq_len(nrow(STG)), function(i) { d <- onset_sev[i];  if (is.na(d)) NA_integer_ else STG[i, d] }, integer(1)),
max_aki_stage_day7  = factor(peak7, levels = c(0,1,2,3), labels = c("Stage 0", "Stage 1", "Stage 2", "Stage 3")),
max_aki_stage_day14  = factor(peak14, levels = c(0,1,2,3), labels = c("Stage 0", "Stage 1", "Stage 2", "Stage 3")),
aki_day7            = factor(aki7,      levels = c(0,1), labels = c("No","Yes")),
aki_day14           = factor(aki14,     levels = c(0,1), labels = c("No","Yes")),
severe_aki_day7     = factor(sev_aki7,  levels = c(0,1), labels = c("No","Yes")),
severe_aki_day14    = factor(sev_aki14, levels = c(0,1), labels = c("No","Yes"))
)
label(df_merged$aki_day7) <- "AKI day 7"
label(df_merged$aki_day14) <- "AKI day 14"
label(df_merged$max_aki_stage_day7) <- "Max AKI staging day 7"
label(df_merged$max_aki_stage_day14) <- "Max AKI staging day 14"
table2Vars = c("aki_day7","aki_day14", "max_aki_stage_day7", "max_aki_stage_day14", "dc_dead", "hospital_los", "censor_group", "cumulative_CBA", "mean_CBA", "colistin_duration")
table2 <- CreateTableOne(vars = table2Vars, data = df_merged, strata = "arm")
table2_df <- print(table2, nonnormal = c("hospital_los", "colistin_duration"), varLabels = T, showAllLevels = FALSE, quote = FALSE)
# Remove blank spaces in values (if any)
table2_df_clean <- apply(table2_df, 2, function(x) gsub("\\s+$", "", x))  # Remove trailing spaces
table2_df_clean <- apply(table2_df_clean, 2, function(x) gsub("^\\s+", "", x))  # Remove leading spaces
table2_df_clean <- apply(table2_df_clean, 2, function(x) gsub("\\s*(\\))", "\\1", x))  # Remove spaces after closing parentheses
table2_df_clean <- apply(table2_df_clean, 2, function(x) gsub("(\\()\\s*", "\\1", x))  # Remove spaces before opening parentheses
table2_df_clean <- apply(table2_df_clean, 2, function(x) gsub("\\(\\s+", "(", x))  # Remove spaces after opening parentheses
write.xlsx(table2_df_clean, "table2.xlsx", rowNames = TRUE, asTable = T)
library(dplyr)
library(broom)
# ---- Helpers ---------------------------------------------------------------
to01 <- function(x) {
# returns integer 0/1, NA if unknown
if (is.logical(x)) return(as.integer(x))
if (is.numeric(x)) {
# keep 0/1; coerce others to NA
out <- rep(NA_integer_, length(x))
out[!is.na(x) & x == 0] <- 0L
out[!is.na(x) & x == 1] <- 1L
return(out)
}
# character / factor
z <- tolower(trimws(as.character(x)))
out <- rep(NA_integer_, length(z))
out[z %in% c("no","0","false","absent","none","negative",
"no aki ≤7d","no aki ≤14d","no severe aki ≤7d","no severe aki ≤14d")] <- 0L
out[z %in% c("yes","1","true","present","positive",
"aki ≤7d","aki ≤14d","severe aki ≤7d","severe aki ≤14d")] <- 1L
as.integer(out)
}
wald_ci_log <- function(est, se, z = 1.96) c(est - z*se, est + z*se)
safe_glm_or <- function(y, arm) {
# arm must be a 2-level factor; returns OR + 95% CI (Wald)
df <- data.frame(y = y, arm = droplevels(factor(arm)))
if (anyNA(df$y) || anyNA(df$arm)) df <- na.omit(df)
if (nlevels(df$arm) != 2 || nrow(df) == 0) {
return(c(OR = NA_real_, LCL = NA_real_, UCL = NA_real_))
}
# make the first level the control
df$arm <- relevel(df$arm, ref = levels(df$arm)[1])
fit <- glm(y ~ arm, family = binomial, data = df)
est <- coef(fit)[["arm" %+% levels(df$arm)[2]]] %||% NA_real_
se  <- sqrt(diag(vcov(fit)))[["arm" %+% levels(df$arm)[2]]] %||% NA_real_
if (is.na(est) || is.na(se)) return(c(OR = NA_real_, LCL = NA_real_, UCL = NA_real_))
ci  <- wald_ci_log(est, se)
c(OR = exp(est), LCL = exp(ci[1]), UCL = exp(ci[2]))
}
# string paste with no space helper
`%+%` <- function(a,b) paste0(a,b)
risk_by_arm <- function(y, arm) {
d <- data.frame(y = y, arm = droplevels(factor(arm))) |> na.omit()
if (nlevels(d$arm) != 2) return(NULL)
d |>
group_by(arm) |>
summarise(rate = mean(y==1), n = n(), .groups = "drop") |>
arrange(arm)
}
arr_rrr <- function(y, arm) {
tab <- risk_by_arm(y, arm)
if (is.null(tab) || nrow(tab) != 2) {
return(c(ARR = NA_real_, ARR_LCL = NA_real_, ARR_UCL = NA_real_,
RRR = NA_real_, RRR_LCL = NA_real_, RRR_UCL = NA_real_))
}
p1 <- tab$rate[1]; n1 <- tab$n[1]   # control = first level
p2 <- tab$rate[2]; n2 <- tab$n[2]   # treatment = second level
# ARR (p2 - p1) with Wald CI
arr <- p2 - p1
se_arr <- sqrt( (p1*(1-p1))/n1 + (p2*(1-p2))/n2 )
ci_arr <- arr + c(-1,1) * 1.96 * se_arr
# RR & RRR with log-normal CI; guard p1==0
if (p1 == 0 || is.na(p1) || is.na(p2)) {
rrr <- NA_real_; rrr_ci <- c(NA_real_, NA_real_)
} else {
rr <- p2 / p1
se_log_rr <- sqrt( (1 - p1)/(p1*n1) + (1 - p2)/(p2*n2) )
ci_rr <- exp(log(rr) + c(-1,1) * 1.96 * se_log_rr)
rrr <- 1 - rr
rrr_ci <- 1 - rev(ci_rr)  # transform
}
c(ARR = arr, ARR_LCL = ci_arr[1], ARR_UCL = ci_arr[2],
RRR = rrr, RRR_LCL = rrr_ci[1], RRR_UCL = rrr_ci[2])
}
cont_diff <- function(y, arm) {
d <- data.frame(y = as.numeric(y), arm = droplevels(factor(arm))) |> na.omit()
if (nlevels(d$arm) != 2) {
return(c(diff = NA_real_, LCL = NA_real_, UCL = NA_real_, p = NA_real_,
mean_arm1 = NA_real_, mean_arm2 = NA_real_))
}
d$arm <- relevel(d$arm, ref = levels(d$arm)[1])
tt <- try(t.test(y ~ arm, data = d), silent = TRUE)
if (inherits(tt, "try-error")) {
return(c(diff = NA_real_, LCL = NA_real_, UCL = NA_real_, p = NA_real_,
mean_arm1 = NA_real_, mean_arm2 = NA_real_))
}
c(diff = unname(diff(tapply(d$y, d$arm, mean))),
LCL = unname(tt$conf.int[1]),
UCL = unname(tt$conf.int[2]),
p = tt$p.value,
mean_arm1 = unname(tt$estimate[1]),
mean_arm2 = unname(tt$estimate[2]))
}
# ---- Specify variables -----------------------------------------------------
binary_vars     <- c("aki_day7","aki_day14","dc_dead")
ordinal_vars    <- c("max_aki_stage_day7","max_aki_stage_day14","censor_group")  # optional (not used in OR/ARR here)
continuous_vars <- c("hospital_los","colistin_duration","cumulative_CBA","mean_CBA")
# ---- Compute binary metrics safely ----------------------------------------
bin_rows <- lapply(binary_vars, function(v) {
y <- to01(df_merged[[v]])
arm <- df_merged$arm
or_vec  <- safe_glm_or(y, arm)
arr_vec <- arr_rrr(y, arm)
rates   <- risk_by_arm(y, arm)
if (is.null(rates)) {
grp1 <- grp2 <- n1 <- n2 <- NA_real_
} else {
grp1 <- rates$rate[1]; n1 <- rates$n[1]
grp2 <- rates$rate[2]; n2 <- rates$n[2]
}
tibble(
variable = v,
group1_rate = grp1, group1_n = n1,
group2_rate = grp2, group2_n = n2,
OR = or_vec["OR"], OR_LCL = or_vec["LCL"], OR_UCL = or_vec["UCL"],
ARR = arr_vec["ARR"], ARR_LCL = arr_vec["ARR_LCL"], ARR_UCL = arr_vec["ARR_UCL"],
RRR = arr_vec["RRR"], RRR_LCL = arr_vec["RRR_LCL"], RRR_UCL = arr_vec["RRR_UCL"]
)
}) |> bind_rows()
# ---- Continuous outcomes: absolute mean differences -----------------------
cont_rows <- lapply(continuous_vars, function(v) {
res <- cont_diff(df_merged[[v]], df_merged$arm)
tibble(
variable = v,
mean_arm1 = res["mean_arm1"],
mean_arm2 = res["mean_arm2"],
diff = res["diff"],       # arm2 - arm1
LCL  = res["LCL"],
UCL  = res["UCL"],
p_value = res["p"]
)
}) |> bind_rows()
# ---- Combine --------------------------------------------------------------
effect_summary <- bind_rows(
bin_rows,
cont_rows
)
# Optional rounding for presentation
effect_summary_out <- effect_summary |>
mutate(across(where(is.numeric), ~ round(., 3)))
effect_summary_out
# Filter for days <= 14
