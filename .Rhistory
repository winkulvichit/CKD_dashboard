x = "Day",
y = "CrCl (mL/min)",
fill = "Study arm"
) +
theme_minimal(base_size = 14) +
theme(legend.position = "top")
library(geepack)
# Fit the GEE model
gee_model <- geeglm(crcl ~ day * arm,
data = df_monitor,
id = id,   # Clustered by patient
family = gaussian, # Continuous outcome
corstr = "exchangeable") # Correlation structure
# Summary of GEE results
summary(gee_model)
# Step 1: Aggregate or process your data as needed (optional)
# Ensure data is grouped by time and arm if necessary.
df_monitor_summary <- df_monitor %>%
group_by(day, arm) %>%
summarise(
mean_crcl = mean(crcl, na.rm = TRUE),
sd_crcl = sd(crcl, na.rm = TRUE),
n = n(),
.groups = "drop"
) %>%
mutate(
se_crcl = sd_crcl / sqrt(n),  # Calculate standard error for confidence interval
ci_lower = mean_crcl - 1.96 * se_crcl,
ci_upper = mean_crcl + 1.96 * se_crcl
)
df_monitor_summary_filtered <- df_monitor_summary %>%
filter(day < 14)
# Plot with corrected data
ggplot(df_monitor_summary_filtered, aes(x = day, y = mean_crcl, color = arm, group = arm)) +
geom_line(linewidth = 1.2) +                     # Line plot for the mean
geom_point(size = 2) +                     # Add points for means
geom_ribbon(aes(ymin = ci_lower, ymax = ci_upper, fill = arm), alpha = 0.2) +  # Confidence intervals
labs(
title = "CrCl trajectory",
x = "Day",
y = "CrCl (mL/min)",
color = "Study arm",
fill = "Study arm"
) +
theme_minimal(base_size = 14) +            # Minimal theme with readable font size
theme(legend.position = "top")
